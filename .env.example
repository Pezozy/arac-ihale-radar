# ═══════════════════════════════════════════
# Araç İhale Radar — Ortam Değişkenleri
# ═══════════════════════════════════════════

# ── Telegram ──────────────────────────────
TELEGRAM_BOT_TOKEN=           # @BotFather'dan alınan token
TELEGRAM_ADMIN_ID=            # Kendi Telegram numeric ID'niz
PUBLIC_CHANNEL_ID=            # @AracIhaleRadar kanal ID'si (@ ile)
BOT_USERNAME=AracIhaleRadarBot
SUPPORT_USERNAME=AracIhaleDestek

# ── AI (Ücretsiz) ────────────────────────
GROQ_API_KEY=                 # console.groq.com'dan alın — ücretsiz

# ── Stripe Ödeme ─────────────────────────
STRIPE_SECRET_KEY=            # Stripe dashboard > Developers > API keys
STRIPE_WEBHOOK_SECRET=        # Stripe webhook endpoint ayarlarından
STRIPE_PAYMENT_LINK_BASIC=    # Stripe payment link URL (₺149/ay plan)
STRIPE_PAYMENT_LINK_PRO=      # Stripe payment link URL (₺299/ay plan)
STRIPE_CUSTOMER_PORTAL_URL=   # Stripe müşteri portalı URL'si

# ── Ayarlar ──────────────────────────────
TRIAL_DAYS=7
PRICE_BASIC_TL=149
PRICE_PRO_TL=299
MIN_DISCOUNT_PCT=15
MAX_AUCTIONS_PER_BROADCAST=5
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
TIMEZONE=Europe/Istanbul
PORT=8080
DB_PATH=./arac_ihale.db
